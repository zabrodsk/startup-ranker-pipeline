# LLM Provider Configuration
# Supported: gemini, openai, anthropic, openrouter
LLM_PROVIDER=gemini
MODEL_NAME=gemini-3.1-flash-lite-preview

# Google Gemini (required when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic (required when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here
# Suggested MODEL_NAME values for LLM_PROVIDER=openai:
# gpt-5-nano | gpt-5-mini | gpt-5 | gpt-4.1-mini

# OpenRouter (required when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Suggested MODEL_NAME values for LLM_PROVIDER=openrouter:
# openrouter/hunter-alpha
# OPENROUTER_SITE_URL=https://your-app.example.com
# OPENROUTER_APP_NAME=Rockaway Deal Intelligence

# Web App Configuration
APP_PASSWORD=9876
# Optional runtime version tags persisted with jobs
# APP_VERSION=dev
# PROMPT_VERSION=v1
# PIPELINE_VERSION=v1
# SCHEMA_VERSION=20260306000000
# Optional: override default session file path (default is $TMPDIR/startup_ranker_sessions.json)
# SESSION_STORE_PATH=/var/lib/startup-ranker/sessions.json
# Optional: override completed jobs persistence path (default is $TMPDIR/startup_ranker_jobs.json)
# JOBS_STORE_PATH=/var/lib/startup-ranker/jobs.json

# LangSmith Configuration (optional, for tracing)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agent-experiment

# Web Search (optional — enables the web search toggle in the UI)
# Supported providers: sonar (Perplexity), brave (Brave Search)
WEB_SEARCH_PROVIDER=sonar
PPLX_API_KEY=your_perplexity_api_key_here
# BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# Web search cost controls (when use_web_search=True)
# WEB_SEARCH_TRIGGER: "answer" = search only when LLM says it lacks evidence (default)
#                    "no_chunks" = legacy: search only when docs have zero chunks
# MAX_PPLX_CALLS_PER_COMPANY=100
# WEB_SEARCH_TRIGGER=answer

# Supabase (optional — enables persistent storage for analyses and Excel downloads after restart)
# Project created via MCP: MVP Startup Ranker (ykxtuqcfhpauddnbxqyq)
SUPABASE_URL=https://ykxtuqcfhpauddnbxqyq.supabase.co
# Get service_role key from: https://supabase.com/dashboard/project/ykxtuqcfhpauddnbxqyq/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
